{
  "info": {
    "name": "Cortex API",
    "description": "REST API for the Cortex context-graph platform (api-service). Set baseUrl and orgId in the collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "orgId",
      "value": "org_demo"
    }
  ],
  "item": [
    {
      "name": "Ops",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/ready",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ready"
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Metrics (Prometheus)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "metrics"
              ]
            },
            "description": ""
          }
        },
        {
          "name": "OpenAPI",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/openapi.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "openapi.json"
              ]
            },
            "description": ""
          }
        }
      ]
    },
    {
      "name": "API",
      "item": [
        {
          "name": "Top risks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/risk/top?limit=20&min_score=0.0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "risk",
                "top"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "min_score",
                  "value": "0.0"
                }
              ]
            },
            "description": "Entities ranked by cross-source urgency."
          }
        },
        {
          "name": "Get node",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/graph/nodes/nd_dep",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "graph",
                "nodes",
                "nd_dep"
              ]
            },
            "description": "A node with its current edges (replace the id)."
          }
        },
        {
          "name": "Node neighborhood",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/graph/nodes/nd_dep/neighborhood?hops=2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "graph",
                "nodes",
                "nd_dep",
                "neighborhood"
              ],
              "query": [
                {
                  "key": "hops",
                  "value": "2"
                }
              ]
            },
            "description": "k-hop subgraph around a node."
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "search"
              ]
            },
            "description": "Hybrid graph + vector search.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"billing\",\n  \"limit\": 20\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Org-Id",
                "value": "{{orgId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "notifications"
              ]
            },
            "description": "The routed notification feed."
          }
        }
      ]
    }
  ]
}