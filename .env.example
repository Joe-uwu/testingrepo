# Cortex configuration. Copy to .env for local overrides. All values have safe defaults
# for the in-memory runtime; the ones below only matter for the kafka runtime.

# runtime: "memory" (default, no external infra) or "kafka" (real bus + stores)
CORTEX_RUNTIME=memory

CORTEX_LOG_LEVEL=INFO
CORTEX_LOG_JSON=true

# --- kafka runtime backing services ---
CORTEX_KAFKA_BOOTSTRAP=localhost:9092
CORTEX_NEO4J_URI=bolt://localhost:7687
CORTEX_NEO4J_USER=neo4j
CORTEX_NEO4J_PASSWORD=password
CORTEX_QDRANT_URL=http://localhost:6333
CORTEX_REDIS_URL=redis://localhost:6379/0

# --- observability ---
# CORTEX_OTEL_ENDPOINT=http://localhost:4317

# --- source connector credentials (only needed to switch a connector off its mock twin) ---
# GitHub connector (Phase 3, fully implemented). Set the org plus ONE auth strategy.
# CORTEX_GITHUB_ORG=my-org
# CORTEX_GITHUB_REPOS=          # optional comma-separated allowlist; empty = all org repos
# 1) Personal access token / installation token:
# CORTEX_GITHUB_TOKEN=
# 2) OAuth web-flow (authorization-code + refresh):
# CORTEX_GITHUB_CLIENT_ID=
# CORTEX_GITHUB_CLIENT_SECRET=
# CORTEX_GITHUB_OAUTH_REFRESH_TOKEN=
# 3) GitHub App installation (needs the 'github' extra for PyJWT):
# CORTEX_GITHUB_APP_ID=
# CORTEX_GITHUB_PRIVATE_KEY_PATH=
# CORTEX_GITHUB_INSTALLATION_ID=
# Webhook receiver (POST /webhooks/github):
# CORTEX_GITHUB_WEBHOOK_SECRET=
#
# Slack connector — bot token (xoxb-...) with channels:history, channels:read scopes:
# CORTEX_SLACK_BOT_TOKEN=
# CORTEX_SLACK_CHANNELS=          # optional comma-separated channel IDs; empty = all public
#
# Jira Cloud connector — Basic auth (account email + API token):
# CORTEX_JIRA_BASE_URL=https://your-site.atlassian.net
# CORTEX_JIRA_EMAIL=
# CORTEX_JIRA_API_TOKEN=
# CORTEX_JIRA_PROJECT=            # optional project key to scope the sync
# CORTEX_JIRA_JQL=               # optional explicit JQL (overrides project scoping)
#
# Notion connector — internal integration secret (secret_...):
# CORTEX_NOTION_TOKEN=
#
# Google Calendar connector — OAuth client + long-lived refresh token:
# CORTEX_CALENDAR_CLIENT_ID=
# CORTEX_CALENDAR_CLIENT_SECRET=
# CORTEX_CALENDAR_REFRESH_TOKEN=
# CORTEX_CALENDAR_CALENDAR_IDS=primary   # comma-separated calendar IDs
#
# PagerDuty connector — REST API key:
# CORTEX_PAGERDUTY_API_TOKEN=

# --- embedder (only needed to switch the vector arm off the offline hashing embedder) ---
# CORTEX_EMBEDDING_PROVIDER=hashing        # or "openai" for any OpenAI-compatible endpoint
# CORTEX_EMBEDDING_MODEL=text-embedding-3-small
# CORTEX_EMBEDDING_API_KEY=
# CORTEX_EMBEDDING_BASE_URL=https://api.openai.com/v1

# --- LLM reasoner (only needed to switch off the deterministic template) ---
# CORTEX_LLM_PROVIDER=template             # or "openai" for any OpenAI-compatible chat endpoint
# CORTEX_LLM_MODEL=gpt-4o-mini
# CORTEX_LLM_API_KEY=
# CORTEX_LLM_BASE_URL=https://api.openai.com/v1
